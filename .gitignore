# pyenv
#   For a library or package, you might want to ignore these files since the user is
#   expected to use the packaging tool.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a application rather than a library, you should ignore it.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is recommended to include poetry.lock in version control.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is recommended to include pdm.lock in version control.
# pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
# Environment files
.env
.env.local
.env.production
.env.development
.env.staging

# IDEs
.idea/
.vscode/
*.swp
*.swo
